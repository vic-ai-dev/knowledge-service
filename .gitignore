# Python
__pycache__/
*.pyc
*.egg-info/
.venv/

# Node
frontend/node_modules/
frontend/dist/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.local
*.local.yaml

# Logs
logs/
*.log


# Build artifacts
dist/
build/
*.egg

# ruff / mypy
.mypy_cache/
.ruff_cache/

# Test artifacts
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# Config (secrets)
backend/config/*.yaml
settings.yaml
settings.yml

# Codex
.codex/

# Runtime data
backend/data/
eval_log/
